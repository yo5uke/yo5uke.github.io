# .renvignore
# renv が R パッケージの依存関係をスキャンする際に除外するファイル・ディレクトリを指定する。
# .gitignore と同じ形式で記述する。
# このファイルが存在する場合、同ディレクトリの .gitignore の代わりに使用される。
# 参考: https://rstudio.github.io/renv/reference/dependencies.html

# Quarto 生成物（スキャン不要）
/_site/
/_freeze/
/.quarto/

# Quarto 拡張機能（Lua スクリプト等、R コードではない）
/_extensions/

# データファイル（大量のテキストファイルを含む可能性があり、スキャン不要）
/data/

# Python 仮想環境
/.venv/

# DVC 関連
/.dvc/
*.dvc

# 静的ライブラリ（JS/CSS）
/site_libs/

# アセット（画像・アイコン等）
/assets/icons/
/assets/images/

# スタイルファイル（CSS/SCSS、R コードではない）
/styles/

# コンポーネント（HTML ファイル）
/components/

# シークレット
/.secrets/

# renv 自体のライブラリ（自動的に除外されるが明示的に記載）
/renv/library/
/renv/staging/
